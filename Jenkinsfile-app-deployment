pipeline {
    agent any
    
    parameters {
        choice(
            name: 'APP_VERSION',
            choices: ['v1', 'v2'],
            description: 'Select application version to deploy'
        )
    }
    
    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 15, unit: 'MINUTES')
    }
    
    environment {
        ANSIBLE_HOST_KEY_CHECKING = 'False'
    }
    
    stages {
        stage('Clone Repository') {
            steps {
                script {
                    echo "📥 Cloning from GitHub..."
                    
                    // WHY: GitHub token credential
                    withCredentials([string(credentialsId: 'github-token', variable: 'GITHUB_TOKEN')]) {
                        sh '''
                        git clone \
                          https://${GITHUB_TOKEN}@github.com/YOUR_USERNAME/terraform-aws-project.git \
                          .
                        
                        git checkout main
                        echo "✓ Repository cloned"
                        '''
                    }
                }
            }
        }
        
        stage('Validate Setup') {
            steps {
                script {
                    echo "Validating Ansible setup..."
                    
                    dir('jenkins-ansible') {
                        sh '''
                        if [ ! -f "inventory/inventory.ini" ]; then
                            echo "❌ inventory.ini not found"
                            exit 1
                        fi
                        
                        if [ ! -f "playbooks/deploy_web_app.yml" ]; then
                            echo "❌ deploy_web_app.yml not found"
                            exit 1
                        fi
                        
                        echo "✓ All files present"
                        '''
                    }
                }
            }
        }
        
        stage('Deploy Version') {
            steps {
                script {
                    echo "🚀 Deploying version: ${APP_VERSION}..."
                    
                    // WHY: SSH key credential for Ansible
                    withCredentials([sshUserPrivateKey(credentialsId: 'aws-ec2-ssh-key', keyFileVariable: 'SSH_KEY_FILE')]) {
                        dir('jenkins-ansible') {
                            sh '''
                            export ANSIBLE_PRIVATE_KEY_FILE=$SSH_KEY_FILE
                            
                            echo "Deploying ${APP_VERSION}..."
                            
                            # Run deployment with version parameter
                            ansible-playbook playbooks/deploy_web_app.yml \
                              -e "app_version=${APP_VERSION}" \
                              -v
                            
                            echo "✓ Version ${APP_VERSION} deployed"
                            '''
                        }
                    }
                }
            }
        }
        
        stage('Verify Version') {
            steps {
                script {
                    echo "Verifying version deployment..."
                    
                    dir('jenkins-ansible') {
                        sh '''
                        WEB_SERVER=$(grep "web_server_1" inventory/inventory.ini | grep "ansible_host" | awk '{print $NF}' | cut -d'=' -f2)
                        
                        echo "Testing: http://$WEB_SERVER"
                        sleep 2
                        
                        RESPONSE=$(curl -s http://$WEB_SERVER)
                        
                        if echo "$RESPONSE" | grep -q "Version"; then
                            echo "✓ Version ${APP_VERSION} deployed successfully"
                        else
                            echo "✗ Verification failed"
                            exit 1
                        fi
                        '''
                    }
                }
            }
        }
    }
    
    post {
        success {
            echo "✅ Application version ${APP_VERSION} deployed!"
        }
        failure {
            echo "❌ Deployment failed!"
        }
    }
}
